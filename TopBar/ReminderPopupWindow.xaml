<Window x:Class="TopBar.ReminderPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reminder"
        SizeToContent="WidthAndHeight"
        MinWidth="280"
        MaxWidth="360"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False">

    <Border Background="#F0161616"
            CornerRadius="10"
            Padding="18,14"
            BorderBrush="#33FFFFFF"
            BorderThickness="1">
        <StackPanel>

            <!-- Header -->
            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,8">
                <TextBlock Text="🔔"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                <TextBlock Text="REMINDER"
                           Foreground="#555555"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Divider -->
            <Rectangle Height="1"
                       Fill="#22FFFFFF"
                       Margin="0,0,0,10"/>

            <!-- Reminder Title -->
            <TextBlock x:Name="TitleText"
                       Foreground="White"
                       FontFamily="Segoe UI"
                       FontSize="14"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Margin="0,0,0,4"/>

            <!-- Reminder Time -->
            <TextBlock x:Name="TimeText"
                       Foreground="#666666"
                       FontFamily="Segoe UI"
                       FontSize="11"
                       Margin="0,0,0,14"/>

            <!-- Countdown + Dismiss -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="CountdownText"
                           Grid.Column="0"
                           Foreground="#444444"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Text="Dismissing in 60s"/>

                <Border Grid.Column="1"
                        Background="#1AFFFFFF"
                        CornerRadius="6"
                        Padding="14,5"
                        Cursor="Hand">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{x:Null}"/>
                    </Border.InputBindings>
                    <TextBlock Text="Dismiss"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               x:Name="DismissText"/>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2AFFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

            </Grid>

        </StackPanel>
    </Border>

</Window>