<UserControl x:Class="TopBar.Widgets.MediaWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             VerticalAlignment="Center"
             Visibility="Collapsed">

    <UserControl.Resources>
        <Style x:Key="MediaButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel Orientation="Horizontal"
                VerticalAlignment="Center">

        <!-- Separator from weather -->
        <Rectangle Width="1"
                   Height="16"
                   Fill="#33FFFFFF"
                   Margin="12,0,12,0"
                   VerticalAlignment="Center"/>

        <!-- Previous -->
        <Button x:Name="PrevButton"
                Style="{StaticResource MediaButton}"
                Click="Prev_Click"
                ToolTip="Previous">
            <svgc:SvgViewbox Source="pack://application:,,,/Assets/Media/skip-back.svg"
                             Width="14"
                             Height="14"/>
        </Button>

        <!-- Play/Pause -->
        <Button x:Name="PlayPauseButton"
                Style="{StaticResource MediaButton}"
                Click="PlayPause_Click"
                ToolTip="Play/Pause">
            <svgc:SvgViewbox x:Name="PlayPauseIcon"
                             Source="pack://application:,,,/Assets/Media/play.svg"
                             Width="14"
                             Height="14"/>
        </Button>

        <!-- Next -->
        <Button x:Name="NextButton"
                Style="{StaticResource MediaButton}"
                Click="Next_Click"
                ToolTip="Next">
            <svgc:SvgViewbox Source="pack://application:,,,/Assets/Media/skip-forward.svg"
                             Width="14"
                             Height="14"/>
        </Button>

        <!-- Song Info -->
        <StackPanel Orientation="Vertical"
                    VerticalAlignment="Center"
                    Margin="12,0,0,0">
            <TextBlock x:Name="TitleText"
                       Foreground="White"
                       FontFamily="Segoe UI"
                       FontSize="12"
                       FontWeight="SemiBold"
                       MaxWidth="500"
                       TextTrimming="CharacterEllipsis"/>
            <TextBlock x:Name="ArtistText"
                       Foreground="White"
                       FontFamily="Segoe UI"
                       FontSize="11"
                       Opacity="0.6"
                       MaxWidth="500"
                       TextTrimming="CharacterEllipsis"/>
        </StackPanel>

    </StackPanel>
</UserControl>