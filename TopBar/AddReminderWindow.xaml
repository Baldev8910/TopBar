<Window x:Class="TopBar.AddReminderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Add Reminder"
        Height="600"
        Width="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ui:ThemeManager.RequestedTheme="Dark">
    

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <StackPanel.Resources>
                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                    <Setter Property="ui:ControlHelper.CornerRadius" Value="6"/>
                </Style>
                <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                    <Setter Property="ui:ControlHelper.CornerRadius" Value="6"/>
                </Style>
                <Style TargetType="DatePicker" BasedOn="{StaticResource {x:Type DatePicker}}">
                    <Setter Property="ui:ControlHelper.CornerRadius" Value="6"/>
                </Style>
                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                    <Setter Property="ui:ControlHelper.CornerRadius" Value="6"/>
                </Style>
            </StackPanel.Resources>

            <!-- Title -->
            <TextBlock Text="Add Reminder"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Margin="0,0,0,20"/>

            <!-- Reminder Title -->
            <TextBlock Text="Title"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Margin="0,0,0,6"/>
            <ui:SimpleStackPanel>
                <TextBox x:Name="TitleBox"
                     ui:ControlHelper.PlaceholderText="Enter reminder title"
                     FontSize="13"
                     Margin="0,0,0,16"/>
            </ui:SimpleStackPanel>

            <!-- Date -->
            <TextBlock Text="Date"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Margin="0,0,0,6"/>
            <DatePicker x:Name="DatePick"
                        Margin="0,0,0,16"
                        HorizontalAlignment="Stretch"/>

            <!-- Time -->
            <TextBlock Text="Time"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Margin="0,0,0,6"/>
            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,8"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Hours -->
                    <Border Grid.Column="0"
                        Width="70"
                        Height="60"
                        Background="Transparent"
                        Cursor="Hand"
                        MouseWheel="HourBorder_MouseWheel">
                        <TextBlock x:Name="HourText"
                                   Text="09"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Separator -->
                    <TextBlock Grid.Column="1"
                               Text=":"
                               FontSize="28"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="8,0"/>

                    <!-- Minutes -->
                    <Border Grid.Column="2"
                            Width="70"
                            Height="60"
                            Background="Transparent"
                            Cursor="Hand"
                            MouseWheel="MinuteBorder_MouseWheel">
                        <TextBlock x:Name="MinuteText"
                                   Text="00"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                </Grid>
            </Border>

            <!-- Mouse Wheel Hint -->
            <TextBlock Text="💡 Scroll mouse wheel on hours/minutes to change"
                       FontSize="11"
                       Opacity="0.6"
                       Margin="0,-10,0,16"/>

            <!-- Repeat -->
            <TextBlock Text="Repeat"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Margin="0,0,0,6"/>
            <ComboBox x:Name="RepeatBox"
                      HorizontalAlignment="Stretch"
                      Margin="0,0,0,24"
                      SelectedIndex="0">
                <ComboBoxItem Content="One-time"/>
                <ComboBoxItem Content="Daily"/>
                <ComboBoxItem Content="Weekly"/>
                <ComboBoxItem Content="Monthly"/>
            </ComboBox>

            <!-- Save Button -->
            <Button Content="Save Reminder"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource AccentButtonStyle}"
                    FontSize="13"
                    Padding="0,10"
                    Click="Save_Click"/>

        </StackPanel>
    </ScrollViewer>

</Window>