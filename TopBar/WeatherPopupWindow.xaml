<Window x:Class="TopBar.WeatherPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        Title="Weather"
        Width="380"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False">

    <Border Background="#F0161616"
            CornerRadius="12"
            BorderBrush="#33FFFFFF"
            BorderThickness="1"
            Padding="20">
        <StackPanel>

            <!-- Header -->
            <TextBlock x:Name="CityText"
                       Text="Detecting..."
                       Foreground="White"
                       FontFamily="Segoe UI"
                       FontSize="13"
                       Opacity="0.5"
                       Margin="0,0,0,2"/>

            <!-- Current Temp + Icon -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="CurrentTemp"
                               Foreground="White"
                               FontFamily="Segoe UI Light"
                               FontSize="52"
                               LineHeight="52"/>
                    <TextBlock x:Name="CurrentCondition"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontSize="15"
                               Opacity="0.8"/>
                    <TextBlock x:Name="FeelsLike"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               Opacity="0.5"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <svgc:SvgViewbox x:Name="CurrentIcon"
                                 Grid.Column="1"
                                 Width="80"
                                 Height="80"
                                 VerticalAlignment="Center"/>
            </Grid>

            <!-- Divider -->
            <Rectangle Height="1" Fill="#22FFFFFF" Margin="0,0,0,16"/>

            <!-- Stats Grid -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Humidity -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                    <TextBlock Text="💧 Humidity"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               Opacity="0.5"/>
                    <TextBlock x:Name="Humidity"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Wind -->
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                    <TextBlock Text="🌬️ Wind"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               Opacity="0.5"/>
                    <TextBlock x:Name="Wind"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- UV Index -->
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,12">
                    <TextBlock Text="☀️ UV Index"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               Opacity="0.5"/>
                    <TextBlock x:Name="UvIndex"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Precipitation -->
                <StackPanel Grid.Row="1" Grid.Column="0">
                    <TextBlock Text="🌧️ Precipitation"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               Opacity="0.5"/>
                    <TextBlock x:Name="Precipitation"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Visibility -->
                <StackPanel Grid.Row="1" Grid.Column="1">
                    <TextBlock Text="🔭 Visibility"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               Opacity="0.5"/>
                    <TextBlock x:Name="Visibility"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Cloud Cover -->
                <StackPanel Grid.Row="1" Grid.Column="2">
                    <TextBlock Text="☁️ Cloud Cover"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               Opacity="0.5"/>
                    <TextBlock x:Name="CloudCover"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,2,0,0"/>
                </StackPanel>

            </Grid>

            <!-- Sunrise / Sunset -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="🌅 Sunrise"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               Opacity="0.5"/>
                    <TextBlock x:Name="Sunrise"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="🌇 Sunset"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               Opacity="0.5"/>
                    <TextBlock x:Name="Sunset"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Divider -->
            <Rectangle Height="1" Fill="#22FFFFFF" Margin="0,0,0,16"/>

            <!-- 6 Day Forecast -->
            <TextBlock Text="6-DAY FORECAST"
                       Foreground="White"
                       FontFamily="Segoe UI"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Opacity="0.5"
                       Margin="0,0,0,12"/>

            <ItemsControl x:Name="ForecastList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Day -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Day}"
                                       Foreground="White"
                                       FontFamily="Segoe UI"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Opacity="0.8"/>

                            <!-- Icon -->
                            <svgc:SvgViewbox Grid.Column="1"
                                             Source="{Binding IconPath}"
                                             Width="24"
                                             Height="24"
                                             VerticalAlignment="Center"/>

                            <!-- Precip chance -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding PrecipChance}"
                                       Foreground="#0078D4"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>

                            <!-- Min / Max -->
                            <StackPanel Grid.Column="3"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding MaxTemp}"
                                           Foreground="White"
                                           FontFamily="Segoe UI"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text=" / "
                                           Foreground="White"
                                           FontFamily="Segoe UI"
                                           FontSize="13"
                                           Opacity="0.4"/>
                                <TextBlock Text="{Binding MinTemp}"
                                           Foreground="White"
                                           FontFamily="Segoe UI"
                                           FontSize="13"
                                           Opacity="0.6"/>
                            </StackPanel>

                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </Border>
</Window>