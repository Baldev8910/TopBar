<Window x:Class="TopBar.SettingsPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Settings"
        Width="320"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False">

    <Border Background="#F0161616"
            CornerRadius="12"
            BorderBrush="#33FFFFFF"
            BorderThickness="1"
            Padding="20">
        <StackPanel>

            <!-- Header -->
            <TextBlock Text="Settings"
                       Foreground="White"
                       FontFamily="Segoe UI"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,0,0,20"/>

            <!-- Bar Height -->
            <TextBlock Text="BAR HEIGHT"
                       Foreground="White"
                       FontFamily="Segoe UI"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Opacity="0.5"
                       Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="BarHeightSlider"
                        Grid.Column="0"
                        Minimum="30"
                        Maximum="60"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        ValueChanged="BarHeightSlider_Changed"
                        VerticalAlignment="Center"/>
                <TextBlock x:Name="BarHeightLabel"
                           Grid.Column="1"
                           Foreground="White"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Bar Opacity -->
            <TextBlock Text="BAR OPACITY"
                       Foreground="White"
                       FontFamily="Segoe UI"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Opacity="0.5"
                       Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="BarOpacitySlider"
                        Grid.Column="0"
                        Minimum="0.3"
                        Maximum="1.0"
                        TickFrequency="0.05"
                        IsSnapToTickEnabled="True"
                        ValueChanged="BarOpacitySlider_Changed"
                        VerticalAlignment="Center"/>
                <TextBlock x:Name="BarOpacityLabel"
                           Grid.Column="1"
                           Foreground="White"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Animation Speed -->
            <TextBlock Text="ANIMATION SPEED"
                       Foreground="White"
                       FontFamily="Segoe UI"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Opacity="0.5"
                       Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="AnimSpeedSlider"
                        Grid.Column="0"
                        Minimum="0.5"
                        Maximum="2.0"
                        TickFrequency="0.1"
                        IsSnapToTickEnabled="True"
                        ValueChanged="AnimSpeedSlider_Changed"
                        VerticalAlignment="Center"/>
                <TextBlock x:Name="AnimSpeedLabel"
                           Grid.Column="1"
                           Foreground="White"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Divider -->
            <Rectangle Height="1" Fill="#22FFFFFF" Margin="0,0,0,16"/>

            <!-- Temperature Unit -->
            <TextBlock Text="TEMPERATURE UNIT"
                       Foreground="White"
                       FontFamily="Segoe UI"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Opacity="0.5"
                       Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <RadioButton x:Name="CelsiusRadio"
                             Content="°C Celsius"
                             Foreground="White"
                             FontFamily="Segoe UI"
                             FontSize="13"
                             Margin="0,0,16,0"
                             Checked="TempUnit_Changed"/>
                <RadioButton x:Name="FahrenheitRadio"
                             Content="°F Fahrenheit"
                             Foreground="White"
                             FontFamily="Segoe UI"
                             FontSize="13"
                             Checked="TempUnit_Changed"/>
            </StackPanel>

            <!-- Weather Refresh Rate -->
            <TextBlock Text="WEATHER REFRESH"
                       Foreground="White"
                       FontFamily="Segoe UI"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Opacity="0.5"
                       Margin="0,0,0,8"/>
            <ComboBox x:Name="RefreshCombo"
                      HorizontalAlignment="Stretch"
                      Margin="0,0,0,16"
                      SelectionChanged="RefreshCombo_Changed">
                <ComboBoxItem Content="Every 5 minutes" Tag="5"/>
                <ComboBoxItem Content="Every 15 minutes" Tag="15"/>
                <ComboBoxItem Content="Every 30 minutes" Tag="30"/>
                <ComboBoxItem Content="Every 60 minutes" Tag="60"/>
            </ComboBox>

            <!-- Divider -->
            <Rectangle Height="1" Fill="#22FFFFFF" Margin="0,0,0,16"/>

            <!-- Launch on Startup -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Launch on Startup"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontSize="13"/>
                    <TextBlock Text="Start TopBar with Windows"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               Opacity="0.5"/>
                </StackPanel>
                <CheckBox x:Name="StartupCheckbox"
                          Grid.Column="1"
                          VerticalAlignment="Center"
                          Checked="Startup_Checked"
                          Unchecked="Startup_Unchecked"/>
            </Grid>

        </StackPanel>
    </Border>
</Window>